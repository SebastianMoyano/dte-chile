# ============================================
# DTE Chile API - Configuración
# ============================================
# Copiar este archivo como .env y completar los valores

# ---- Servidor ----
APP_NAME=DTE Chile API
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ---- SII Chile ----
# Ambiente: certificacion (maullin) o produccion (palena)
SII_AMBIENTE=certificacion

# Datos de resolución SII (obtenidos al autorizar emisión electrónica)
SII_FECHA_RESOLUCION=2014-08-22
SII_NUMERO_RESOLUCION=80

# ---- Empresa (Emisor por defecto) ----
# RUT de la empresa sin puntos con guión (ej: 76543210-5)
EMPRESA_RUT=
EMPRESA_RAZON_SOCIAL=
EMPRESA_GIRO=
EMPRESA_CODIGO_ACTIVIDAD=
EMPRESA_DIRECCION=
EMPRESA_COMUNA=
EMPRESA_CIUDAD=
EMPRESA_EMAIL=
EMPRESA_TELEFONO=

# ---- Certificado Digital ----
# Ruta al archivo .p12/.pfx del certificado (opcional, se puede enviar por API)
CERTIFICADO_PATH=
CERTIFICADO_PASSWORD=

# ---- Base de Datos ----
# SQLite (por defecto) o PostgreSQL
DATABASE_URL=sqlite:///./dte_database.db

# ---- Seguridad / JWT ----
# `setup.py` GENERA valores fuertes para JWT_SECRET_KEY y DTE_MASTER_KEY. Si editas a
# mano, pon secretos aleatorios (>=32 chars). En producción, la app NO arranca con estos
# placeholders. Genera JWT con: openssl rand -hex 32
JWT_SECRET_KEY=cambiar_esto_por_una_clave_segura_de_al_menos_32_caracteres
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Clave Fernet que cifra los certificados del keystore. Genera con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# OJO: si la cambias, los certificados YA guardados no se podrán descifrar (re-súbelos).
DTE_MASTER_KEY=

# ---- CORS ----
# Orígenes permitidos (separados por coma). Con "*" se DESHABILITAN las credenciales
# (regla CORS). Para uso local/self-hosted restringe a tu origen, ej:
#   CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ORIGINS=*

# ---- Logs ----
LOG_LEVEL=INFO
LOG_FILE=logs/dte_api.log

# ---- Almacenamiento de archivos ----
# Directorio para guardar DTEs emitidos, PDFs, etc.
STORAGE_PATH=./storage

# Token del endpoint de correos del SII (skill correos-sii). Lo rota el usuario.
SII_MAIL_TOKEN=
